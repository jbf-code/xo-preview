# XO Preview Platform - Environment Variables

# Server
PORT=3000
BASE_URL=http://localhost:3000
SESSION_SECRET=change-this-to-a-random-string

# Users (format: email:password:name)
# If no USER_* vars are set, default dev users are used
USER_1=jbf@xo.dk:changeme:JBF
USER_2=cca@xo.dk:changeme:CCA

# Node environment
NODE_ENV=production
